{
  "name": "action-octopus-build-information",
  "private": true,
  "description": "GitHub Action that generates build information for Octopus Deploy",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.js --bundle --platform=node --target=node24 --format=esm --outfile=dist/index.js --sourcemap --banner:js=\"import { createRequire } from 'node:module'; const require = createRequire(import.meta.url);\"",
    "debug": "node -r dotenv/config src/main.js",
    "clean": "shx rm -rf dist/*",
    "lint": "eslint . --cache --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky install"
  },
  "license": "ISC",
  "engines": {
    "node": "^24.0.0"
  },
  "dependencies": {
    "@actions/core": "^1.7.0",
    "@actions/github": "^5.0.1",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@vitest/eslint-plugin": "^1.6.20",
    "dotenv": "^16.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.0.0",
    "husky": "^8.0.1",
    "js-yaml": "^4.1.0",
    "lint-staged": "^13.0.3",
    "prettier": "^2.6.2",
    "shx": "^0.3.4",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "src/**/*.js": "eslint --cache --fix",
    "tests/**/*.js": "eslint --cache --fix"
  },
  "prettier": {
    "printWidth": 100
  }
}
