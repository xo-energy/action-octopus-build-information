{
  "name": "action-octopus-build-information",
  "private": true,
  "description": "GitHub Action that generates build information for Octopus Deploy",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.js --bundle --platform=node --target=node24 --format=esm --outfile=dist/index.js --sourcemap --banner:js=\"import { createRequire } from 'node:module'; const require = createRequire(import.meta.url);\"",
    "debug": "node -r dotenv/config src/index.js",
    "clean": "shx rm -rf dist/*",
    "lint": "eslint . --cache --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "license": "ISC",
  "engines": {
    "node": "^24.0.0"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/eslint-plugin": "^1.6.20",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "js-yaml": "^5.1.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.5",
    "shx": "^0.4.0",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "src/**/*.js": "eslint --cache --fix",
    "tests/**/*.js": "eslint --cache --fix"
  },
  "prettier": {
    "printWidth": 100
  }
}
