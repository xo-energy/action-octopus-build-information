{
  "plugins": [
    "@vitest",
    "prettier"
  ],
  "extends": [
    "eslint:recommended",
    "plugin:@vitest/legacy-recommended",
    "plugin:prettier/recommended"
  ],
  "env": {
    "commonjs": true,
    "es6": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-plusplus": [
      "error",
      {
        "allowForLoopAfterthoughts": true
      }
    ],
    "prettier/prettier": [
      "warn"
    ],
    "prefer-destructuring": "off"
  },
  "overrides": [
    {
      "files": ["tests/**/*.js"],
      "env": {
        "@vitest/env": true
      }
    }
  ]
}
